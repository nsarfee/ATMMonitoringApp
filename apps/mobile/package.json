{
  "name": "@atm/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_ROUTER_IMPORT_MODE=sync expo start",
    "android": "EXPO_ROUTER_IMPORT_MODE=sync expo start --android",
    "ios": "EXPO_ROUTER_IMPORT_MODE=sync expo start --ios",
    "web": "EXPO_ROUTER_IMPORT_MODE=sync expo start --web",
    "export:web": "EXPO_ROUTER_IMPORT_MODE=sync npx expo export --platform web",
    "postinstall": "node scripts/fix-expo-router.js"
  },
  "dependencies": {
    "@atm/shared": "*",
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~51.0.0",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "^0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "patch-package": "^8.0.1",
    "typescript": "~5.3.3"
  }
